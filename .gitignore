# Git worktrees
.worktrees/

# Secrets (never commit)
.secrets
*.env
.env.*
.firebaserc
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
*.egg-info/
.eggs/
dist/
build/

# R
.Rhistory
.RData
.Rproj.user

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Project run artifacts (optional: uncomment to ignore generated runs)
projects/*/run*/

# Node (for jsPsych Builder when used)
node_modules/
npm-debug.log

# Firebase: local CLI state/cache (do not commit)
.firebase/

# Firebase Hosting deploy target (copy of implementer output)
public/
firebase.generated.json

# Static results-viewer snapshot built by src/viewer/freeze.py (regenerated, never committed)
viewer_dist/

# remote_jobs (SLURM cluster deployment): per-submission JSON, fetched logs, local env
remote_jobs/.runs/
remote_jobs/logs/
remote_jobs/.env.local
# Allow the .env.example template to be tracked (overrides the top-level .env.* rule).
!remote_jobs/.env.example

# Local scratch / working notes (never commit)
*.local.txt
*_cache/
scratch/

# Large generated text dumps (e.g. PDF text-extraction output from extract_pdf.py).
# gt.txt (~21 MB) is already tracked — untrack it with: git rm --cached gt.txt
gt.txt

# Large regenerable mega-analysis predictions (fit via analysis/behavioral/fit_mega_models.py)
analysis/behavioral/data/mega_model_predictions.csv

# Quarto render artifacts (regenerate with quarto render)
analysis/behavioral/*.html
analysis/behavioral/*_files/
