#!/usr/bin/env bash
# prove_it: fast tests—runs every time Claude finishes a response
# Fast unit/integration tests: everything except the slow PyMC NUTS runs.
set -e
trap 'rc=$?; command -v prove_it >/dev/null 2>&1 && prove_it record --name fast-tests --result $rc' EXIT
exec .venv/bin/python -m pytest -q -m "not slow"
