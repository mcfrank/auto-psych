"""
People evaluate the randomness of a sequence strictly based on the square root of the absolute number of heads it contains. This means their perception of randomness increases with more heads, but they exhibit diminishing sensitivity to differences in head counts as the overall number of heads becomes larger, and their choices are subject to a constant lapse rate.
"""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    # Stimulus inputs
    h_a = pm.Data("h_a", np.zeros(1, dtype="int64"))
    h_b = pm.Data("h_b", np.zeros(1, dtype="int64"))
    
    # Cognitive parameters
    tau = pm.HalfNormal("tau", sigma=10.0)
    lapse = pm.Beta("lapse", alpha=1.0, beta=9.0)
    
    # Mechanism: square root of heads
    sqrt_h_a = pt.sqrt(pt.cast(h_a, "float64"))
    sqrt_h_b = pt.sqrt(pt.cast(h_b, "float64"))
    
    # Decision rule: sigmoid of the difference in square root of heads
    diff = sqrt_h_a - sqrt_h_b
    p_base = pm.math.sigmoid(tau * diff)
    
    # Incorporate lapse rate for random guessing and clip for numerical stability
    p_left = pm.Deterministic("p_left", pt.clip(lapse / 2.0 + (1.0 - lapse) * p_base, 1e-6, 1.0 - 1e-6))
    
    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
EOF
