import pandas as pd
import numpy as np

df = pd.read_csv('/Users/ben/Documents/auto-psych/data/subjective_randomness/impossible_holdout_recovery/impossible_holdout_runs/more_heads_more_random/experiment3/model_loop/responses.csv')

h_diff = df['h_a'] - df['h_b']
acc_h = np.mean((h_diff > 0) == df['chose_left'])
acc_h_strict = np.mean(((h_diff > 0).astype(int)) == df['chose_left']) # ignores ties

p_diff = df['p_a'] - df['p_b']
acc_p = np.mean((p_diff > 0) == df['chose_left'])

df['pred_h'] = (h_diff > 0).astype(int)
df.loc[h_diff == 0, 'pred_h'] = 0.5

df['pred_p'] = (p_diff > 0).astype(int)
df.loc[p_diff == 0, 'pred_p'] = 0.5

def acc_with_ties(diff, true_val):
    correct = 0
    for d, t in zip(diff, true_val):
        if d > 0 and t == 1: correct += 1
        elif d < 0 and t == 0: correct += 1
        elif d == 0: correct += 0.5
    return correct / len(true_val)

print(f"Acc h_diff: {acc_with_ties(h_diff, df['chose_left']):.3f}")
print(f"Acc p_diff: {acc_with_ties(p_diff, df['chose_left']):.3f}")

# Check when they disagree
mask = np.sign(h_diff) != np.sign(p_diff)
df_disagree = df[mask & (h_diff != 0) & (p_diff != 0)]
if len(df_disagree) > 0:
    acc_h_disagree = np.mean((df_disagree['h_a'] > df_disagree['h_b']).astype(int) == df_disagree['chose_left'])
    acc_p_disagree = np.mean((df_disagree['p_a'] > df_disagree['p_b']).astype(int) == df_disagree['chose_left'])
    print(f"When they disagree (N={len(df_disagree)}):")
    print(f"  Acc h_diff: {acc_h_disagree:.3f}")
    print(f"  Acc p_diff: {acc_p_disagree:.3f}")
else:
    print("They never disagree strictly (excluding ties)")

