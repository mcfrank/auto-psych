import pandas as pd
import arviz as az

df = pd.read_csv('/Users/ben/Documents/auto-psych/data/subjective_randomness/impossible_holdout_recovery/impossible_holdout_runs/more_heads_more_random/experiment3/model_loop/responses.csv')

with pm.Model() as model:
    h_a = pm.Data("h_a", df['h_a'].values)
    h_b = pm.Data("h_b", df['h_b'].values)
    chose_left = pm.Data("chose_left", df['chose_left'].values)
    
    tau = pm.HalfNormal("tau", sigma=5.0)
    
    # +0.5 to avoid log(0)
    log_a = pt.log(pt.cast(h_a, "float64") + 0.5)
    log_b = pt.log(pt.cast(h_b, "float64") + 0.5)
    
    p_left = pm.Deterministic("p_left", pm.math.sigmoid(tau * (log_a - log_b)))
    
    pm.Bernoulli("response", p=p_left, observed=chose_left)
    
    idata = pm.sample(1000, tune=1000, cores=1, return_inferencedata=True, idata_kwargs={"log_likelihood": True})
    loo = az.loo(idata)
    print("ELPD-LOO Log No Lapse:", loo.elpd_loo)
