import numpy as np
import pymc as pm
import pytensor.tensor as pt
import pandas as pd
import arviz as az

df = pd.read_csv('/Users/ben/Documents/auto-psych/data/subjective_randomness/impossible_holdout_recovery/impossible_holdout_runs/more_heads_more_random/experiment3/model_loop/responses.csv')

with pm.Model() as model:
    h_a = pm.Data("h_a", df['h_a'].values)
    h_b = pm.Data("h_b", df['h_b'].values)
    chose_left = pm.Data("chose_left", df['chose_left'].values)
    
    lapse = pm.Beta("lapse", alpha=1.0, beta=9.0)
    
    # 1 if a > b, 0 if a < b, 0.5 if a == b
    is_greater = pt.gt(h_a, h_b)
    is_less = pt.lt(h_a, h_b)
    is_equal = pt.eq(h_a, h_b)
    
    # Convert boolean to float
    step_prob = is_greater * 1.0 + is_less * 0.0 + is_equal * 0.5
    
    p_left = pm.Deterministic("p_left", lapse / 2.0 + (1.0 - lapse) * step_prob)
    
    pm.Bernoulli("response", p=p_left, observed=chose_left)
    
    idata = pm.sample(1000, tune=1000, cores=1, return_inferencedata=True)
    loo = az.loo(idata)
    print(loo)
