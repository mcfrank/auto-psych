People evaluate the randomness of a sequence by focusing strictly on the absolute number of tails it contains, viewing tails as evidence against randomness. Thus, sequences with fewer tails are perceived as more random, regardless of the sequence's total length.
import numpy as np
import pymc as pm
import pytensor.tensor as pt

"""
People evaluate the randomness of a sequence by focusing strictly on the absolute number of tails it contains, viewing tails as evidence against randomness. Thus, sequences with fewer tails are perceived as more random, regardless of the sequence's total length.
"""

with pm.Model() as model:
    # Stimulus inputs
    n_a = pm.Data("n_a", np.zeros(1, dtype="int64"))
    h_a = pm.Data("h_a", np.zeros(1, dtype="int64"))
    n_b = pm.Data("n_b", np.zeros(1, dtype="int64"))
    h_b = pm.Data("h_b", np.zeros(1, dtype="int64"))

    # Free cognitive parameter
    tau = pm.HalfNormal("tau", sigma=1.0)

    # Cognitive mechanism: count tails (n - h)
    t_a = n_a - h_a
    t_b = n_b - h_b

    # Fewer tails means more random. 
    # If t_b > t_a, p_left should be > 0.5.
    p_left = pm.Deterministic("p_left", pm.math.sigmoid(tau * (t_b - t_a)))

    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
