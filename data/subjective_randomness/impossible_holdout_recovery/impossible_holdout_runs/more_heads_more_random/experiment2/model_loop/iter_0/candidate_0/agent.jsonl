"""
People evaluate the randomness of a sequence strictly based on the number of heads it contains, but the impact of the head count scales non-linearly according to an inferred power-law parameter.
"""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    # Stimulus inputs
    # h_a and h_b are integers but using float64 avoids dtype issues with pt.pow
    h_a = pm.Data("h_a", np.zeros(1, dtype="float64"))
    h_b = pm.Data("h_b", np.zeros(1, dtype="float64"))
    
    # Free cognitive parameters
    tau = pm.HalfNormal("tau", sigma=10.0)
    gamma = pm.HalfNormal("gamma", sigma=3.0)
    
    # Non-linear scaling of heads
    # Add small epsilon to h_a and h_b to prevent NaN gradients when h=0 and gamma < 1
    score_a = pt.pow(h_a + 1e-4, gamma)
    score_b = pt.pow(h_b + 1e-4, gamma)
    
    # Probability of choosing left (sequence A)
    p_left_raw = pm.math.sigmoid(tau * (score_a - score_b))
    
    # Clamp p_left for numerical stability
    p_left = pm.Deterministic("p_left", pt.clip(p_left_raw, 1e-6, 1 - 1e-6))
    
    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
EOF
