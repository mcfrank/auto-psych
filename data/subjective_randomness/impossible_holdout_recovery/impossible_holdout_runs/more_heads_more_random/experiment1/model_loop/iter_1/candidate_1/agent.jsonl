"""
People evaluate the randomness of a sequence based on the absolute number of heads it contains, but their perception of this quantity follows Stevens's power law. When comparing two sequences, they compute a randomness score that is the absolute head count raised to an inferred exponent, accommodating either accelerating or decelerating sensitivity to additional heads.
"""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    # Stimulus inputs
    h_a = pm.Data("h_a", np.zeros(1, dtype="int64"))
    h_b = pm.Data("h_b", np.zeros(1, dtype="int64"))

    # Free cognitive parameters
    tau = pm.HalfNormal("tau", sigma=1.0)
    alpha = pm.HalfNormal("alpha", sigma=2.0)
    
    # Stevens's power law transformation
    # Adding a small constant prevents log(0) / inf gradient issues when h=0
    score_a = (h_a + 1e-4) ** alpha
    score_b = (h_b + 1e-4) ** alpha

    # Choice probability based on the difference in power-law scores
    p_left_raw = pm.math.sigmoid(tau * (score_a - score_b))
    p_left = pm.Deterministic("p_left", pt.clip(p_left_raw, 1e-6, 1 - 1e-6))

    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
