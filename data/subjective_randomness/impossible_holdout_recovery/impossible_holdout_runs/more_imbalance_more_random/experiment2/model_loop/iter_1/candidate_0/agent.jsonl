"""
People judge sequence randomness based on outcome frequencies, but rely on the unnormalized raw difference in counts between heads and tails rather than the proportion, perceiving sequences with a larger absolute difference in counts as more random.
"""
import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    # Stimulus inputs
    n_a = pm.Data("n_a", np.zeros(1, dtype="int64"))
    h_a = pm.Data("h_a", np.zeros(1, dtype="int64"))
    n_b = pm.Data("n_b", np.zeros(1, dtype="int64"))
    h_b = pm.Data("h_b", np.zeros(1, dtype="int64"))

    # Free cognitive parameter
    tau = pm.HalfNormal("tau", sigma=10.0)

    # Raw absolute difference in counts (heads vs tails)
    # tails = n - h
    # diff = h - tails = h - (n - h) = 2*h - n
    raw_diff_a = pt.abs(2 * h_a - n_a)
    raw_diff_b = pt.abs(2 * h_b - n_b)

    # Larger raw difference -> more random
    # Using cast to float64 for the score just to be safe
    score_a = pt.cast(raw_diff_a, "float64")
    score_b = pt.cast(raw_diff_b, "float64")
    
    p_left_raw = pm.math.sigmoid(tau * (score_a - score_b))
    p_left = pm.Deterministic("p_left", pt.clip(p_left_raw, 1e-6, 1 - 1e-6))
    
    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
