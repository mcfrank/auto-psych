"""
People judge sequence randomness by intuitively assessing the statistical surprise of the outcome frequencies, paradoxically perceiving sequences whose heads and tails counts are less likely under a fair coin as more random.
"""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    # Stimulus inputs
    n_a = pm.Data("n_a", np.zeros(1, dtype="int64"))
    h_a = pm.Data("h_a", np.zeros(1, dtype="int64"))
    n_b = pm.Data("n_b", np.zeros(1, dtype="int64"))
    h_b = pm.Data("h_b", np.zeros(1, dtype="int64"))

    # Free cognitive parameter
    tau = pm.HalfNormal("tau", sigma=1.0)

    # Convert to float for mathematical operations
    fn_a = pt.cast(n_a, "float64")
    fh_a = pt.cast(h_a, "float64")
    fn_b = pt.cast(n_b, "float64")
    fh_b = pt.cast(h_b, "float64")

    # Log probability of the counts under a fair coin
    log_p_count_a = (
        pt.gammaln(fn_a + 1.0)
        - pt.gammaln(fh_a + 1.0)
        - pt.gammaln(fn_a - fh_a + 1.0)
        + fn_a * pt.log(0.5)
    )
    
    log_p_count_b = (
        pt.gammaln(fn_b + 1.0)
        - pt.gammaln(fh_b + 1.0)
        - pt.gammaln(fn_b - fh_b + 1.0)
        + fn_b * pt.log(0.5)
    )

    # Statistical surprise is the negative log probability
    surprise_a = -log_p_count_a
    surprise_b = -log_p_count_b

    # People perceive sequences with higher surprise as MORE random
    p_left = pm.Deterministic(
        "p_left", 
        pm.math.sigmoid(tau * (surprise_a - surprise_b))
    )

    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
