    # Log probability of the counts under a fair coin
    log_p_count_a = (
        pt.gammaln(fn_a + 1.0)
        - pt.gammaln(fh_a + 1.0)
        - pt.gammaln(fn_a - fh_a + 1.0)
        + fn_a * pt.log(0.5)
    )
    
    log_p_count_b = (
        pt.gammaln(fn_b + 1.0)
        - pt.gammaln(fh_b + 1.0)
        - pt.gammaln(fn_b - fh_b + 1.0)
