import json
import random
import itertools

def generate_all_sequences(min_len=3, max_len=8):
    seqs = []
    for length in range(min_len, max_len + 1):
        for p in itertools.product("HT", repeat=length):
            seqs.append("".join(p))
    return seqs

def main():
    seqs = generate_all_sequences(3, 8)
    candidates = []
    random.seed(42)
    # 200 random pairs
    for _ in range(200):
        a = random.choice(seqs)
        b = random.choice(seqs)
        if a != b:
            candidates.append({"sequence_a": a, "sequence_b": b})
    
    with open("/Users/ben/Documents/auto-psych/data/subjective_randomness/holdout_recovery/holdout_runs/encoding_compressibility/experiment1/design/candidates_small.json", "w") as f:
        json.dump(candidates, f, indent=2)

if __name__ == "__main__":
    main()
