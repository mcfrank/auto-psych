import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    # Feature inputs
    max_run_a = pm.Data("max_run_norm_a", np.zeros(1, dtype="float64"))
    max_run_b = pm.Data("max_run_norm_b", np.zeros(1, dtype="float64"))
    
    periodicity_a = pm.Data("periodicity_a", np.zeros(1, dtype="float64"))
    periodicity_b = pm.Data("periodicity_b", np.zeros(1, dtype="float64"))
    
    imbalance_a = pm.Data("imbalance_a", np.zeros(1, dtype="float64"))
    imbalance_b = pm.Data("imbalance_b", np.zeros(1, dtype="float64"))
    
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    
    # Cognitive parameters for compressibility penalties
    w_run = pm.HalfNormal("w_run", sigma=5.0)
    w_per = pm.HalfNormal("w_per", sigma=5.0)
    w_imb = pm.HalfNormal("w_imb", sigma=5.0)
    side_bias = pm.Normal("side_bias", mu=0.0, sigma=1.0)
    
    # Higher penalty = more compressible = less random
    penalty_a = w_run * max_run_a + w_per * periodicity_a + w_imb * imbalance_a
    penalty_b = w_run * max_run_b + w_per * periodicity_b + w_imb * imbalance_b
    
    # Probability of choosing 'left' as more random
    p_left = pm.Deterministic(
        "p_left",
        pm.math.sigmoid((penalty_b - penalty_a) + side_bias)
    )
    
    pm.Bernoulli("response", p=p_left, observed=chose_left)
