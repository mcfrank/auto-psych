"""PyMC model refining the Bayesian diagnosticity model by inferring the specific characteristics of people's mental alternative models rather than hardcoding them."""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

def _logsumexp2(a, b):
    m = pt.maximum(a, b)
    return m + pt.log(pt.exp(a - m) + pt.exp(b - m))

def _normalized_iid_log_prob(n, h, p_heads):
    n_f = pt.cast(n, "float64")
    h_f = pt.cast(h, "float64")
    tails_f = n_f - h_f
    denom = pt.maximum(n_f, 1.0)
    return (h_f * pt.log(p_heads) + tails_f * pt.log(1.0 - p_heads)) / denom

def _normalized_markov_log_prob(n, alts, switch_prob):
    n_f = pt.cast(n, "float64")
    alts_f = pt.cast(alts, "float64")
    stays_f = pt.maximum(n_f - 1.0, 0.0) - alts_f
    denom = pt.maximum(n_f, 1.0)
    return (
        pt.log(0.5) + alts_f * pt.log(switch_prob) + stays_f * pt.log(1.0 - switch_prob)
    ) / denom

def _score_sequence(n, h, alts, alt_prior, bias_share, alt_switch_prob, streak_switch_prob, bias_heads_prob):
    fair = _normalized_iid_log_prob(n, h, pt.as_tensor_variable(0.5))
    alternating = _normalized_markov_log_prob(n, alts, alt_switch_prob)
    streaky = _normalized_markov_log_prob(n, alts, streak_switch_prob)
    bias_h = _normalized_iid_log_prob(n, h, bias_heads_prob)
    bias_t = _normalized_iid_log_prob(n, h, 1.0 - bias_heads_prob)
    biased = _logsumexp2(pt.log(0.5) + bias_h, pt.log(0.5) + bias_t)

    alt_weight = alt_prior
    bias_weight = (1.0 - alt_prior) * bias_share
    streak_weight = (1.0 - alt_prior) * (1.0 - bias_share)
    
    # logsumexp over alternative models
    alternatives = _logsumexp2(
        _logsumexp2(
            pt.log(alt_weight) + alternating,
            pt.log(bias_weight) + biased,
        ),
        pt.log(streak_weight) + streaky,
    )
    return fair - alternatives

