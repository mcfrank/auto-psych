import json
import random
import itertools

def generate_sequences():
    seqs = []
    for length in range(3, 9):
        for p in itertools.product('HT', repeat=length):
            seqs.append("".join(p))
    return seqs

all_seqs = generate_sequences()
candidates = []

# To ensure diversity, let's include all combinations of different lengths? No, just random sampling is fine if we sample enough.
random.seed(42)
# Sample 5000 pairs
pairs = set()
while len(pairs) < 5000:
    a, b = random.sample(all_seqs, 2)
    # enforce a sort to avoid symmetric duplicates? No, order matters maybe? The model is p_left, so A vs B. We can just use A and B.
    pairs.add((a, b))

for a, b in pairs:
    candidates.append({"sequence_a": a, "sequence_b": b})

with open("/Users/ben/Documents/auto-psych/data/subjective_randomness/holdout_recovery/holdout_runs/bayesian_diagnosticity/experiment2/design/candidates.json", "w") as f:
    json.dump(candidates, f)

