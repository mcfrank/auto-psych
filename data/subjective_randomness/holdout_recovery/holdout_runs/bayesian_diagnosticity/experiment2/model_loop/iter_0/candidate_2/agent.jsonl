import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    # Stimulus inputs
    imbalance_a = pm.Data("imbalance_a", np.zeros(1, dtype="float64"))
    imbalance_b = pm.Data("imbalance_b", np.zeros(1, dtype="float64"))
    
    p_alts_a = pm.Data("p_alts_a", np.zeros(1, dtype="float64"))
    p_alts_b = pm.Data("p_alts_b", np.zeros(1, dtype="float64"))
    
    n_a = pm.Data("n_a", np.zeros(1, dtype="float64"))
    n_b = pm.Data("n_b", np.zeros(1, dtype="float64"))

    # Cognitive parameters
    # Ideal alternation rate
    theta_alt = pm.Uniform("theta_alt", lower=0.35, upper=0.95)
    
    # Feature weights (simplex)
    alt_weight = pm.Uniform("alt_weight", lower=0.01, upper=0.99)
    balance_weight = 1.0 - alt_weight
    
    # Evidence scaling: how much does sequence length magnify the penalty?
    # 0 = no scaling (like basic prototype model), 1 = linear scaling
    length_power = pm.Uniform("length_power", lower=0.0, upper=2.0)
    
    # Decision parameters
    beta = pm.HalfNormal("beta", sigma=5.0)
    side_bias = pm.Normal("side_bias", mu=0.0, sigma=2.0)

    # Scale distance by a power of sequence length
    weight_n_a = pt.pow(n_a, length_power)
    weight_n_b = pt.pow(n_b, length_power)
    
    # Penalize deviations from prototype (ideal balance and ideal alternation rate)
    penalty_a = weight_n_a * (
        balance_weight * imbalance_a + alt_weight * pt.abs(p_alts_a - theta_alt)
    )
    penalty_b = weight_n_b * (
        balance_weight * imbalance_b + alt_weight * pt.abs(p_alts_b - theta_alt)
    )

    # Deterministic probability of choosing left
    p_left = pm.Deterministic(
        "p_left",
        pm.math.sigmoid(beta * (penalty_b - penalty_a) + side_bias),
    )

    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
