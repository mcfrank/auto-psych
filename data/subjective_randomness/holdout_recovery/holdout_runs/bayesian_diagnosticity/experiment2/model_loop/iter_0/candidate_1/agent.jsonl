    bias_share = pm.Uniform("bias_share", lower=0.01, upper=0.99)
    beta = pm.Uniform("beta", lower=0.2, upper=12.0)
    side_bias = pm.Uniform("side_bias", lower=-2.0, upper=2.0)
    
    # Newly inferred parameters instead of hardcoded
    alt_switch_prob = pm.Uniform("alt_switch_prob", lower=0.51, upper=0.99)
    streak_switch_prob = pm.Uniform("streak_switch_prob", lower=0.01, upper=0.49)
    bias_head_prob = pm.Uniform("bias_head_prob", lower=0.51, upper=0.99)

    # Score each sequence
    score_a = _score_sequence(n_a, h_a, alts_a, alt_prior, bias_share, alt_switch_prob, streak_switch_prob, bias_head_prob)
    score_b = _score_sequence(n_b, h_b, alts_b, alt_prior, bias_share, alt_switch_prob, streak_switch_prob, bias_head_prob)

    # Deterministic probability of choosing left
    p_left = pm.Deterministic(
        "p_left",
        pm.math.sigmoid(beta * (score_a - score_b) + side_bias)
    )

    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
