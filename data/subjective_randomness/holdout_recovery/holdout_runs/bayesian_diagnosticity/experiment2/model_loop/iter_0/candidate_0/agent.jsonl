import numpy as np
import pymc as pm
import pytensor.tensor as pt

ALT_SWITCH_PROB = 0.95
STREAK_SWITCH_PROB = 0.15
BIAS_HEAD_PROB = 0.85

def _logsumexp2(a, b):
    m = pt.maximum(a, b)
    return m + pt.log(pt.exp(a - m) + pt.exp(b - m))

def _iid_log_prob(n, h, p_heads):
    n_f = pt.cast(n, "float64")
    h_f = pt.cast(h, "float64")
    tails_f = n_f - h_f
    return (h_f * np.log(p_heads) + tails_f * np.log(1.0 - p_heads))

def _markov_log_prob(n, alts, switch_prob):
    n_f = pt.cast(n, "float64")
    alts_f = pt.cast(alts, "float64")
    stays_f = pt.maximum(n_f - 1.0, 0.0) - alts_f
    return np.log(0.5) + alts_f * np.log(switch_prob) + stays_f * np.log(1.0 - switch_prob)

def _score_sequence(n, h, alts, alt_prior, bias_share):
    fair = _iid_log_prob(n, h, 0.5)
    alternating = _markov_log_prob(n, alts, ALT_SWITCH_PROB)
    streaky = _markov_log_prob(n, alts, STREAK_SWITCH_PROB)
    bias_h = _iid_log_prob(n, h, BIAS_HEAD_PROB)
    bias_t = _iid_log_prob(n, h, 1.0 - BIAS_HEAD_PROB)
    biased = _logsumexp2(np.log(0.5) + bias_h, np.log(0.5) + bias_t)

    alt_weight = alt_prior
    bias_weight = (1.0 - alt_prior) * bias_share
    streak_weight = (1.0 - alt_prior) * (1.0 - bias_share)
    
    # logsumexp over alternative models
    alternatives = _logsumexp2(
        _logsumexp2(
            pt.log(alt_weight) + alternating,
            pt.log(bias_weight) + biased,
        ),
        pt.log(streak_weight) + streaky,
    )
    # The score is the Log Bayes Factor: log P(D | fair) - log P(D | alternatives)
    return fair - alternatives

