    bias_alt = _continuous_bias_log_prob(n, h, c_bias)
    markov_alt = _continuous_markov_log_prob(n, alts, c_markov)
    
    alternatives = _logsumexp2(
        pt.log(alt_prior) + markov_alt,
        pt.log(1.0 - alt_prior) + bias_alt
    )
