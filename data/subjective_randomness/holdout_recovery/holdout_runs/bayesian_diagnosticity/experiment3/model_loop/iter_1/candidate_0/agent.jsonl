import numpy as np

def logsumexp2(a, b):
    m = np.maximum(a, b)
    return m + np.log(np.exp(a - m) + np.exp(b - m))

def mix_normalized(n, log_pA, log_pB, wA=0.5, wB=0.5):
    # Mixing normalized
    norm_A = log_pA / n
    norm_B = log_pB / n
    return logsumexp2(np.log(wA) + norm_A, np.log(wB) + norm_B)

def normalize_mixed(n, log_pA, log_pB, wA=0.5, wB=0.5):
    # Normalize after mixing
    mixed = logsumexp2(np.log(wA) + log_pA, np.log(wB) + log_pB)
    return mixed / n

