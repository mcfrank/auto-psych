import numpy as np

def integrated_bias_log_prob(n, h):
    from scipy.special import gammaln
    return gammaln(h + 1) + gammaln(n - h + 1) - gammaln(n + 2)

def integrated_markov_log_prob(n, alts):
    from scipy.special import gammaln
    stays = np.maximum(n - 1, 0) - alts
    # if n=0, return 0 (handle edge case)
    return np.log(0.5) + gammaln(alts + 1) + gammaln(stays + 1) - gammaln(np.maximum(n, 1))

print(integrated_bias_log_prob(10, 5) / 10)
print(integrated_markov_log_prob(10, 5) / 10)
