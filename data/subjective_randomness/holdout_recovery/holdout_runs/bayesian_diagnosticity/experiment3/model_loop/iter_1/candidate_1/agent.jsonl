import numpy as np
import pymc as pm
import pytensor.tensor as pt

def _logsumexp2(a, b):
    m = pt.maximum(a, b)
    return m + pt.log(pt.exp(a - m) + pt.exp(b - m))

def _scaled_iid_log_prob(n, h, p_heads, gamma):
    n_f = pt.cast(n, "float64")
    h_f = pt.cast(h, "float64")
    tails_f = n_f - h_f
    denom = pt.maximum(n_f, 1.0) ** gamma
    return (h_f * pt.log(p_heads) + tails_f * pt.log(1.0 - p_heads)) / denom

def _scaled_markov_log_prob(n, alts, switch_prob, gamma):
    n_f = pt.cast(n, "float64")
    alts_f = pt.cast(alts, "float64")
    stays_f = pt.maximum(n_f - 1.0, 0.0) - alts_f
    denom = pt.maximum(n_f, 1.0) ** gamma
    return (
        np.log(0.5) + alts_f * pt.log(switch_prob) + stays_f * pt.log(1.0 - switch_prob)
    ) / denom

def _score_sequence(n, h, alts, alt_prior, bias_share, alt_switch_prob, streak_switch_prob, bias_head_prob, gamma):
    fair = _scaled_iid_log_prob(n, h, 0.5, gamma)
    alternating = _scaled_markov_log_prob(n, alts, alt_switch_prob, gamma)
    streaky = _scaled_markov_log_prob(n, alts, streak_switch_prob, gamma)
    bias_h = _scaled_iid_log_prob(n, h, bias_head_prob, gamma)
    bias_t = _scaled_iid_log_prob(n, h, 1.0 - bias_head_prob, gamma)
    biased = _logsumexp2(np.log(0.5) + bias_h, np.log(0.5) + bias_t)

    alt_weight = alt_prior
    bias_weight = (1.0 - alt_prior) * bias_share
    streak_weight = (1.0 - alt_prior) * (1.0 - bias_share)
    
    alternatives = _logsumexp2(
        _logsumexp2(
            pt.log(alt_weight) + alternating,
            pt.log(bias_weight) + biased,
        ),
        pt.log(streak_weight) + streaky,
    )
    return fair - alternatives

with pm.Model() as model:
    n_a = pm.Data("n_a", np.zeros(1, dtype="int64"))
    h_a = pm.Data("h_a", np.zeros(1, dtype="int64"))
    alts_a = pm.Data("alts_a", np.zeros(1, dtype="int64"))
