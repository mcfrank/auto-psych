        # By adding a baseline of log(0.5) we put it roughly on the same scale as other LLs
        run_ll = np.log(0.5) + w_run * max_run_norm
        period_ll = np.log(0.5) + w_period * periodicity

        # Weights
        w1 = alt_prior
        w2 = (1.0 - w1) * bias_share
        w3 = (1.0 - w1) * (1.0 - bias_share) * run_share
        w4 = (1.0 - w1) * (1.0 - bias_share) * (1.0 - run_share) * period_share
        w5 = (1.0 - w1) * (1.0 - bias_share) * (1.0 - run_share) * (1.0 - period_share)
        
        # logsumexp over all 5 alternative models
        alt1 = _logsumexp2(pt.log(w1) + alternating, pt.log(w2) + biased)
        alt2 = _logsumexp2(pt.log(w3) + streaky, pt.log(w4) + run_ll)
        alt3 = _logsumexp2(alt1, alt2)
        alternatives = _logsumexp2(alt3, pt.log(w5) + period_ll)
        
        return fair - alternatives

    score_a = _score_sequence(n_a, h_a, alts_a, max_run_norm_a, periodicity_a)
    score_b = _score_sequence(n_b, h_b, alts_b, max_run_norm_b, periodicity_b)

    p_left = pm.Deterministic(
        "p_left",
        pm.math.sigmoid(beta * (score_a - score_b) + side_bias)
    )

    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)

