    beta = pm.Uniform("beta", lower=0.2, upper=12.0)
    side_bias = pm.Uniform("side_bias", lower=-2.0, upper=2.0)
    
    # Refinement: Add a lapse rate for random clicking/inattention
    # This prevents outlier responses from overly penalizing the model's likelihood
    lapse_rate = pm.Beta("lapse_rate", alpha=1.0, beta=9.0)

    # Score each sequence
    score_a = _score_sequence(n_a, h_a, alts_a, alt_prior, bias_share)
    score_b = _score_sequence(n_b, h_b, alts_b, alt_prior, bias_share)

    # Deterministic probability of choosing left
    p_left_pure = pm.math.sigmoid(beta * (score_a - score_b) + side_bias)
    p_left = pm.Deterministic(
        "p_left",
        lapse_rate * 0.5 + (1.0 - lapse_rate) * p_left_pure
    )

    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
