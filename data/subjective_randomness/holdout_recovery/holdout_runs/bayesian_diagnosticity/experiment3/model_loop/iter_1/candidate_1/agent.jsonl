    score_b = _score_sequence(n_b, h_b, alts_b, alt_prior, bias_share, alt_switch_prob, streak_switch_prob, bias_head_prob, gamma)

    p_left = pm.Deterministic("p_left", pm.math.sigmoid(beta * (score_a - score_b) + side_bias))

