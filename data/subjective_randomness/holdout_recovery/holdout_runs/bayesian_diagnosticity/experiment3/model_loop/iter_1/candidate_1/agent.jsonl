import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    n_a = pm.Data("n_a", np.zeros(1, dtype="int64"))
    h_a = pm.Data("h_a", np.zeros(1, dtype="int64"))
    alts_a = pm.Data("alts_a", np.zeros(1, dtype="int64"))
    
    n_b = pm.Data("n_b", np.zeros(1, dtype="int64"))
    h_b = pm.Data("h_b", np.zeros(1, dtype="int64"))
    alts_b = pm.Data("alts_b", np.zeros(1, dtype="int64"))

    # Add a lapse rate
    lapse_rate = pm.Beta("lapse_rate", alpha=1.0, beta=9.0)
    
    w_heads = pm.HalfNormal("w_heads", sigma=5.0)
    w_alts = pm.HalfNormal("w_alts", sigma=5.0)
    w_interaction = pm.Normal("w_interaction", mu=0.0, sigma=5.0)
    
    beta = pm.Uniform("beta", lower=0.1, upper=10.0)
    side_bias = pm.Normal("side_bias", mu=0.0, sigma=2.0)
    
    n_a_f = pt.cast(n_a, "float64")
    h_a_f = pt.cast(h_a, "float64")
    alts_a_f = pt.cast(alts_a, "float64")
    n_b_f = pt.cast(n_b, "float64")
    h_b_f = pt.cast(h_b, "float64")
    alts_b_f = pt.cast(alts_b, "float64")

    # z-scores for heads
    z_heads_a_sq = ((h_a_f - n_a_f/2.0)**2) / pt.maximum(n_a_f/4.0, 1e-6)
    z_heads_b_sq = ((h_b_f - n_b_f/2.0)**2) / pt.maximum(n_b_f/4.0, 1e-6)
    
    # z-scores for alternations
    n_a_alts = pt.maximum(n_a_f - 1.0, 1e-6)
    n_b_alts = pt.maximum(n_b_f - 1.0, 1e-6)
    z_alts_a_sq = ((alts_a_f - n_a_alts/2.0)**2) / (n_a_alts/4.0)
    z_alts_b_sq = ((alts_b_f - n_b_alts/2.0)**2) / (n_b_alts/4.0)

    # For sequences of length 1, z_alts should be 0
    z_alts_a_sq = pt.switch(pt.eq(n_a, 1), 0.0, z_alts_a_sq)
    z_alts_b_sq = pt.switch(pt.eq(n_b, 1), 0.0, z_alts_b_sq)
    
    # Score is the "unrandomness" (deviation from fair coin). We want negative score to be more random.
    # Actually, people judge sequences with too FEW alternations as non-random, and too MANY as also non-random?
    # Wait, Kahneman & Tversky found people expect MORE alternations than chance!
    # So the expected alts is NOT (n-1)/2, but maybe theta_alt * (n-1)?
    
    theta_alt = pm.Uniform("theta_alt", lower=0.4, upper=0.9)
    z_alts_a_sq_subj = ((alts_a_f - theta_alt * n_a_alts)**2) / pt.maximum(n_a_alts * theta_alt * (1-theta_alt), 1e-6)
    z_alts_b_sq_subj = ((alts_b_f - theta_alt * n_b_alts)**2) / pt.maximum(n_b_alts * theta_alt * (1-theta_alt), 1e-6)
    
    z_alts_a_sq_subj = pt.switch(pt.eq(n_a, 1), 0.0, z_alts_a_sq_subj)
    z_alts_b_sq_subj = pt.switch(pt.eq(n_b, 1), 0.0, z_alts_b_sq_subj)

    score_a = w_heads * z_heads_a_sq + w_alts * z_alts_a_sq_subj + w_interaction * z_heads_a_sq * z_alts_a_sq_subj
    score_b = w_heads * z_heads_b_sq + w_alts * z_alts_b_sq_subj + w_interaction * z_heads_b_sq * z_alts_b_sq_subj

    # Probability of choosing left (A is more random than B, so A should have LOWER score)
    p_left_pure = pm.math.sigmoid(beta * (score_b - score_a) + side_bias)
    p_left = pm.Deterministic("p_left", lapse_rate * 0.5 + (1.0 - lapse_rate) * p_left_pure)

    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)

if __name__ == "__main__":
    from src.models.pymc_inference import fit_model
    from pathlib import Path
    
    csv_path = Path("data/subjective_randomness/holdout_recovery/holdout_runs/bayesian_diagnosticity/experiment3/model_loop/responses.csv")
    
    try:
        # Save as ztest_model.py
        pass
    except Exception as e:
        import traceback
