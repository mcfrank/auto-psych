"""
People judge the randomness of a sequence by the proportion of the sequence made up of its longest continuous run, perceiving sequences where a single run occupies a larger fraction of the total length as less random.
"""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    max_run_norm_a = pm.Data("max_run_norm_a", np.zeros(1, dtype="float64"))
    max_run_norm_b = pm.Data("max_run_norm_b", np.zeros(1, dtype="float64"))

    # Free parameter mapping the difference in normalized run length to choice probability
    beta_run_norm = pm.Normal("beta_run_norm", mu=0.0, sigma=10.0)

    # p_left is the probability of choosing sequence A as more random.
    # If A has a larger normalized run, it is less random, so beta_run_norm should be negative.
    p_left = pm.Deterministic("p_left", pm.math.sigmoid(beta_run_norm * (max_run_norm_a - max_run_norm_b)))

    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
EOF
