import json
import random
import os

EXP_DIR = "/Users/ben/Documents/auto-psych/data/subjective_randomness/holdout_smoke/holdout_runs/prototype_similarity/experiment1"
OUT_PATH = os.path.join(EXP_DIR, "design", "candidates.json")

# generate all sequences up to length 8
sequences = []
for length in range(3, 9):
    for i in range(1 << length):
        seq = ""
        for bit in range(length):
            seq += "H" if (i & (1 << bit)) else "T"
        sequences.append(seq)

print(f"Total sequences: {len(sequences)}")

random.seed(42)
candidates = []
for _ in range(300):
    seq_a = random.choice(sequences)
    seq_b = random.choice(sequences)
    candidates.append({
        "sequence_a": seq_a,
        "sequence_b": seq_b
    })

os.makedirs(os.path.dirname(OUT_PATH), exist_ok=True)
with open(OUT_PATH, "w") as f:
    json.dump(candidates, f, indent=2)
print(f"Wrote {len(candidates)} candidates to {OUT_PATH}")
