import pymc as pm
import pytensor.tensor as pt
import numpy as np

with pm.Model() as model:
    n = pt.constant(np.array([4, 7, 7, 4]))
    h = pt.constant(np.array([2, 7, 0, 0]))
    theta = pt.constant(0.8)
    
    A = h * pt.log(theta) + (n-h) * pt.log(1-theta)
    B = h * pt.log(1-theta) + (n-h) * pt.log(theta)
    
    # log(0.5 * (e^A + e^B)) = log(0.5) + logaddexp(A, B)
    log_bias = pt.log(0.5) + pt.logaddexp(A, B)
    log_fair = n * pt.log(0.5)
    
    lbf = log_fair - log_bias
    
    print(lbf.eval())
