import pandas as pd
import pytensor.tensor as pt
import pymc as pm
import numpy as np
import scipy.optimize as opt

df = pd.read_csv('/Users/ben/Documents/auto-psych/data/outer_loop/subjective_randomness/experiment2/model_loop/responses.csv')

def fit_2features(f1a, f1b, f2a, f2b):
    f1a = df[f1a].values; f1b = df[f1b].values
    f2a = df[f2a].values; f2b = df[f2b].values
    y = df['chose_left'].values
    
    def nll(w):
        w1, w2 = w
        p = 1 / (1 + np.exp(-(w1 * (f1a - f1b) + w2 * (f2a - f2b))))
        p = np.clip(p, 1e-10, 1 - 1e-10)
        return -np.sum(y * np.log(p) + (1-y) * np.log(1-p))
        
    res = opt.minimize(nll, [0.0, 0.0])
    return res.fun

print("h_a and n_a:", -fit_2features('h_a', 'h_b', 'n_a', 'n_b'))
print("alts_a and n_a:", -fit_2features('alts_a', 'alts_b', 'n_a', 'n_b'))
print("h_a and alts_a:", -fit_2features('h_a', 'h_b', 'alts_a', 'alts_b'))
