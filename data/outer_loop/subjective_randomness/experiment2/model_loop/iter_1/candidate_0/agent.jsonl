import pymc as pm
import pytensor.tensor as pt
import numpy as np

with pm.Model() as model:
    n = pt.constant(np.array([4, 7, 7, 4]))
    h = pt.constant(np.array([2, 7, 0, 0]))
    theta = pt.constant(0.8)
    
    p_heads = pt.pow(theta, h) * pt.pow(1-theta, n-h)
    p_tails = pt.pow(1-theta, h) * pt.pow(theta, n-h)
    p_mix = 0.5 * (p_heads + p_tails)
    
    log_bias = pt.log(p_mix)
    log_fair = n * pt.log(0.5)
    
    lbf = log_fair - log_bias
    
    print(lbf.eval())
