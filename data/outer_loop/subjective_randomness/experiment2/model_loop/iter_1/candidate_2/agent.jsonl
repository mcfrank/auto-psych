print("tails:", eval_score(n_a - h_a, n_b - h_b))
print("net_tails:", eval_score((n_a - h_a) - h_a, (n_b - h_b) - h_b))
print("-h^2:", eval_score(-(h_a**2), -(h_b**2)))
print("log(-h):", eval_score(-np.log(h_a+1), -np.log(h_b+1)))
