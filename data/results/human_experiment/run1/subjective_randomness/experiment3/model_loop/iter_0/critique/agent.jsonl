import pandas as pd
import numpy as np

df = pd.read_csv('/scratch/users/benpry/auto-psych/outer_loop_live/run1/data/subjective_randomness/experiment3/model_loop/responses.csv')

def stat1(df):
    typical_a = (df['p_a'] >= 0.4) & (df['p_a'] <= 0.6) & (df['p_alts_a'] >= 0.4) & (df['p_alts_a'] <= 0.6)
    typical_b = (df['p_b'] >= 0.4) & (df['p_b'] <= 0.6) & (df['p_alts_b'] >= 0.4) & (df['p_alts_b'] <= 0.6)
    subset = df[typical_a & typical_b & (df['n_a'] != df['n_b'])]
    if len(subset) == 0: return 0.0
    chose_longer = ((df['n_a'] > df['n_b']) & df['chose_left']) | ((df['n_b'] > df['n_a']) & (df['chose_left']==0))
    return chose_longer.mean(), len(subset)

def stat2(df):
    subset = df[(df['max_run_a'] > df['max_run_b'] + 1) & (abs(df['p_alts_a'] - df['p_alts_b']) <= 0.1)]
    if len(subset) == 0: return 0.0, 0
    return subset['chose_left'].mean(), len(subset)

def stat3(df):
    subset = df[(abs(df['p_a'] - 0.5) > 0.35) & (abs(df['p_b'] - 0.5) > 0.15) & (abs(df['p_b'] - 0.5) < 0.25)]
    if len(subset) == 0: return 0.0, 0
    return subset['chose_left'].mean(), len(subset)

def stat4(df):
    subset = df[(df['p_alts_a'] < 0.2) & (df['p_alts_b'] > 0.3) & (df['p_alts_b'] < 0.4)]
    if len(subset) == 0: return 0.0, 0
    return subset['chose_left'].mean(), len(subset)

def stat5(df):
    subset = df[(df['p_a'] >= 0.4) & (df['p_a'] <= 0.6) & (df['p_b'] >= 0.4) & (df['p_b'] <= 0.6) & (df['p_alts_a'] > 0.8) & (df['p_alts_b'] < 0.2)]
    if len(subset) == 0: return 0.0, 0
    return subset['chose_left'].mean(), len(subset)

def stat6(df):
    subset = df[(df['rep_motifs_a'] > df['rep_motifs_b']) & (abs(df['p_alts_a'] - df['p_alts_b']) <= 0.1)]
    if len(subset) == 0: return 0.0, 0
    return subset['chose_left'].mean(), len(subset)

def stat7(df):
    imbalanced_a = abs(df['p_a'] - 0.5) > 0.3
    imbalanced_b = abs(df['p_b'] - 0.5) > 0.3
    subset = df[imbalanced_a & imbalanced_b & (df['n_a'] != df['n_b'])]
    if len(subset) == 0: return 0.0, 0
    chose_longer = ((df['n_a'] > df['n_b']) & df['chose_left']) | ((df['n_b'] > df['n_a']) & (df['chose_left']==0))
    return chose_longer.mean(), len(subset)

def stat8(df):
    subset = df[(df['alt_motifs_a'] > df['alt_motifs_b']) & (abs(df['p_alts_a'] - df['p_alts_b']) <= 0.1)]
    if len(subset) == 0: return 0.0, 0
    return subset['chose_left'].mean(), len(subset)

print("Stat 1:", stat1(df))
print("Stat 2:", stat2(df))
print("Stat 3:", stat3(df))
print("Stat 4:", stat4(df))
print("Stat 5:", stat5(df))
print("Stat 6:", stat6(df))
print("Stat 7:", stat7(df))
print("Stat 8:", stat8(df))

