import json
import random
import itertools

seqs = []
for length in range(2, 9):
    for p in itertools.product('HT', repeat=length):
        seqs.append(''.join(p))

candidates = []

# ensure some diversity by random selection
for _ in range(300):
    a = random.choice(seqs)
    b = random.choice(seqs)
    candidates.append({
        'sequence_a': a,
        'sequence_b': b
    })

import os
os.makedirs('/scratch/users/benpry/auto-psych/outer_loop_live/run1/data/subjective_randomness/experiment3/design', exist_ok=True)
with open('/scratch/users/benpry/auto-psych/outer_loop_live/run1/data/subjective_randomness/experiment3/design/candidates.json', 'w') as f:
    json.dump(candidates, f, indent=2)

print('Done generating candidates')
"
