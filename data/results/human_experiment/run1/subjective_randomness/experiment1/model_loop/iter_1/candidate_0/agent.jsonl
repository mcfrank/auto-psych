import numpy as np
import pymc as pm
import pytensor.tensor as pt
import pandas as pd

df = pd.read_csv('/scratch/users/benpry/auto-psych/outer_loop_live/run1/data/subjective_randomness/experiment1/model_loop/responses.csv')

with pm.Model() as model:
    n_a = pm.Data("n_a", df['n_a'].values)
    h_a = pm.Data("h_a", df['h_a'].values)
    alts_a = pm.Data("alts_a", df['alts_a'].values)

    n_b = pm.Data("n_b", df['n_b'].values)
    h_b = pm.Data("h_b", df['h_b'].values)
    alts_b = pm.Data("alts_b", df['alts_b'].values)

    ideal_p = pm.Beta("ideal_p", alpha=2.0, beta=2.0)
    ideal_alt = pm.Beta("ideal_alt", alpha=2.0, beta=2.0)
    
    w_p = pm.HalfNormal("w_p", sigma=5.0)
    w_alt = pm.HalfNormal("w_alt", sigma=5.0)
    base_typ = pm.Normal("base_typ", mu=0.0, sigma=5.0)
    
    p_a = h_a / pt.maximum(n_a, 1)
    p_b = h_b / pt.maximum(n_b, 1)
    
    alt_rate_a = alts_a / pt.maximum(n_a - 1, 1)
    alt_rate_b = alts_b / pt.maximum(n_b - 1, 1)
    
    typ_a = base_typ - (w_p * pt.square(p_a - ideal_p) + w_alt * pt.square(alt_rate_a - ideal_alt))
    typ_b = base_typ - (w_p * pt.square(p_b - ideal_p) + w_alt * pt.square(alt_rate_b - ideal_alt))
    
    # Randomness is typicality integrated over length
    rand_a = n_a * typ_a
    rand_b = n_b * typ_b
    
    p_left_raw = pm.math.sigmoid(rand_a - rand_b)
    p_left = pm.Deterministic("p_left", pt.clip(p_left_raw, 1e-6, 1.0 - 1e-6))
    
    chose_left = pm.Data("chose_left", df['chose_left'].values)
    pm.Bernoulli("response", p=p_left, observed=chose_left)

print("Model created.")
