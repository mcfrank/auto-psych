df['alt_motifs_diff'] = df['alt_motifs_a'] - df['alt_motifs_b']
print('Alt motifs diff corr:', np.corrcoef(df['alt_motifs_diff'], df['chose_left'])[0,1])

df['n_diff'] = df['n_a'] - df['n_b']
print('Length diff corr:', np.corrcoef(df['n_diff'], df['chose_left'])[0,1])

df['imbalance_diff'] = df['imbalance_a'] - df['imbalance_b']
print('Imbalance diff corr:', np.corrcoef(df['imbalance_diff'], df['chose_left'])[0,1])

df['p_alts_diff'] = df['p_alts_a'] - df['p_alts_b']
