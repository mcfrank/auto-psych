import numpy as np
df = pd.read_csv('/scratch/users/benpry/auto-psych/outer_loop_live/run1/data/subjective_randomness/experiment2/model_loop/responses.csv')

def corr(col1, col2, mask=None):
    if mask is not None:
        d = df[mask]
    else:
        d = df
    return np.corrcoef(d[col1], d[col2])[0,1]

print('Periodicity diff corr:', corr('periodicity_a', 'chose_left', df['periodicity_a'] != df['periodicity_b']))
# to be proper, we should do diff
