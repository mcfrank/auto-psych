import pandas as pd
import numpy as np
from scipy.stats import pearsonr

df = pd.read_csv('/scratch/users/benpry/auto-psych/outer_loop_live/run2/data/subjective_randomness/experiment1/model_loop/responses.csv')

# Let's find the best theta for rate vs unnormalized
best_r_rate = 0
best_r_unnorm = 0

for theta in np.linspace(0.4, 0.9, 50):
    diff_a_rate = df['p_alts_a'] - theta
    penalty_a_rate = np.where(diff_a_rate > 0, 0.2 * diff_a_rate, -1.0 * diff_a_rate)
    
    diff_b_rate = df['p_alts_b'] - theta
    penalty_b_rate = np.where(diff_b_rate > 0, 0.2 * diff_b_rate, -1.0 * diff_b_rate)
    
    score_rate = -(penalty_a_rate - penalty_b_rate)
    r_rate = pearsonr(score_rate, df['chose_left'])[0]
    if r_rate > best_r_rate: best_r_rate = r_rate
    
    diff_a_unnorm = df['alts_a'] - theta * (df['n_a'] - 1)
    penalty_a_unnorm = np.where(diff_a_unnorm > 0, 0.2 * diff_a_unnorm, -1.0 * diff_a_unnorm)
    
    diff_b_unnorm = df['alts_b'] - theta * (df['n_b'] - 1)
    penalty_b_unnorm = np.where(diff_b_unnorm > 0, 0.2 * diff_b_unnorm, -1.0 * diff_b_unnorm)
    
    score_unnorm = -(penalty_a_unnorm - penalty_b_unnorm)
    r_unnorm = pearsonr(score_unnorm, df['chose_left'])[0]
    if r_unnorm > best_r_unnorm: best_r_unnorm = r_unnorm

print('Best r rate:', best_r_rate)
print('Best r unnorm:', best_r_unnorm)
