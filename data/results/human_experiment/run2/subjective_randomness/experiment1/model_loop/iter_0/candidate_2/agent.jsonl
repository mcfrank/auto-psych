def local_representativeness(seq, w=4):
    if len(seq) < w: return 0.0
    # absolute deviation from expected 0.5 ratio
    devs = []
    for i in range(len(seq) - w + 1):
        devs.append(abs(seq[i:i+w].count('H')/w - 0.5))
    return np.mean(devs)

