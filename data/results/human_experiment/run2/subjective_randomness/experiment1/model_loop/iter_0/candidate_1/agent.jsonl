with pm.Model() as model:
    n = pt.as_tensor_variable(np.array([8], dtype='float64'))
    h = pt.as_tensor_variable(np.array([2], dtype='float64'))
    alts = pt.as_tensor_variable(np.array([3], dtype='float64'))
    
    p_h = pt.clip(h / n, 1e-6, 1 - 1e-6)
    kl_unigram = p_h * pt.log(p_h / 0.5) + (1 - p_h) * pt.log((1 - p_h) / 0.5)
    
    p_alt = pt.clip(alts / (n - 1), 1e-6, 1 - 1e-6)
    theta_alt = 0.6
    kl_trans = p_alt * pt.log(p_alt / theta_alt) + (1 - p_alt) * pt.log((1 - p_alt) / (1 - theta_alt))
    
    score = -(kl_unigram + kl_trans)
    print(score.eval())
