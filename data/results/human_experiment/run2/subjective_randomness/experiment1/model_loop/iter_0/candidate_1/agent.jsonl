    theta_alt = 0.6
    log_p_A = pt.gammaln(N + 1) - pt.gammaln(alts + 1) - pt.gammaln(N - alts + 1) + alts * pt.log(theta_alt) + (N - alts) * pt.log(1 - theta_alt)
    
    score = log_p_H + log_p_A
    print(score.eval())
