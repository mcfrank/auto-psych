import numpy as np
import pymc as pm
import pytensor.tensor as pt

def log_binom_prob(n, k, p):
    n_f = pt.cast(n, "float64")
    k_f = pt.cast(k, "float64")
    log_comb = pt.gammaln(n_f + 1.0) - pt.gammaln(k_f + 1.0) - pt.gammaln(n_f - k_f + 1.0)
    return log_comb + k_f * pt.log(p) + (n_f - k_f) * pt.log(1.0 - p)

with pm.Model() as model:
    n = pt.as_tensor_variable(np.array([8, 8, 8], dtype='int64'))
    k = pt.as_tensor_variable(np.array([4, 7, 1], dtype='int64'))
    
    p_val = 0.6
    print(log_binom_prob(n, k, p_val).eval())
