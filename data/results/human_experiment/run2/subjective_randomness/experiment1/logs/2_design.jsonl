import json
import random
import itertools
import os

def generate_sequences():
    seqs = []
    for length in range(2, 9):
        for p in itertools.product('HT', repeat=length):
            seqs.append("".join(p))
    return seqs

def main():
    seqs = generate_sequences()
    candidates = set()
    random.seed(42)
    
    same_length_pairs = []
    diff_length_pairs = []
    
    for length in range(2, 9):
        len_seqs = [s for s in seqs if len(s) == length]
        for a, b in itertools.combinations(len_seqs, 2):
            same_length_pairs.append((a, b))
            
    for l1 in range(2, 9):
        for l2 in range(l1 + 1, 9):
            len_seqs1 = [s for s in seqs if len(s) == l1]
            len_seqs2 = [s for s in seqs if len(s) == l2]
            for a in len_seqs1:
                for b in len_seqs2:
                    diff_length_pairs.append((a, b))
                    
    selected_same = random.sample(same_length_pairs, 100)
    selected_diff = random.sample(diff_length_pairs, 200)
    
    all_selected = selected_same + selected_diff
    random.shuffle(all_selected)
    
    output = []
    for a, b in all_selected:
        output.append({"sequence_a": a, "sequence_b": b})
        
    os.makedirs('/scratch/users/benpry/auto-psych/outer_loop_live/run2/data/subjective_randomness/experiment1/design', exist_ok=True)
    with open('/scratch/users/benpry/auto-psych/outer_loop_live/run2/data/subjective_randomness/experiment1/design/candidates.json', 'w') as f:
        json.dump(output, f, indent=2)

if __name__ == '__main__':
    main()
EOF
