import numpy as np

def compute_features(sequence_a: str, sequence_b: str):
    def run_length_entropy(seq):
        if not seq: return 0.0
        runs = []
        current_run = 1
        for i in range(1, len(seq)):
            if seq[i] == seq[i-1]:
                current_run += 1
            else:
                runs.append(current_run)
                current_run = 1
        runs.append(current_run)
        
        # Count frequencies of each run length
        counts = {}
        for r in runs:
            counts[r] = counts.get(r, 0) + 1
            
        # Compute entropy
        total_runs = len(runs)
        entropy = 0.0
        for r, c in counts.items():
            p = c / total_runs
            entropy -= p * np.log(p)
        return entropy
        
    return {
        "run_entropy_a": run_length_entropy(sequence_a),
        "run_entropy_b": run_length_entropy(sequence_b)
    }

print(compute_features("HTHTHT", "HHTHTT"))
print(compute_features("HHHHHH", "HTHHTT"))
