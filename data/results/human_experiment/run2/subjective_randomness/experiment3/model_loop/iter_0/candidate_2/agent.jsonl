def lz_complexity(s):
    if not s: return 0
    sub_strings = set()
    n = len(s)
    ind = 0
    inc = 1
    while True:
        if ind + inc > n:
            break
        sub_str = s[ind : ind + inc]
        if sub_str in sub_strings:
            inc += 1
        else:
            sub_strings.add(sub_str)
            ind += inc
            inc = 1
    return len(sub_strings)

print("HTHTHT:", lz_complexity("HTHTHT"))
print("HHHHHH:", lz_complexity("HHHHHH"))
