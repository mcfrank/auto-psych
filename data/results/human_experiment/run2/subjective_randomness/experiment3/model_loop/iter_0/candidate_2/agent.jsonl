def lz_complexity(s):
    if not s: return 0
    i, k, l = 0, 1, 1
    c = 1
    while True:
        if i + k > len(s):
            break
        if s[i:i+k] in s[0:i+k-1]:
            k += 1
        else:
            c += 1
            i += k
            k = 1
    return c

