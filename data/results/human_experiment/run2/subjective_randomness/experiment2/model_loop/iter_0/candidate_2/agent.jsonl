def get_run_counts(s):
    runs = []
    current_run = 1
    for i in range(1, len(s)):
        if s[i] == s[i-1]:
            current_run += 1
        else:
            runs.append(current_run)
            current_run = 1
    runs.append(current_run)
    c1 = sum(1 for r in runs if r == 1)
    c2 = sum(1 for r in runs if r == 2)
    c3_plus = sum(1 for r in runs if r >= 3)
    return c1, c2, c3_plus

