import pandas as pd
import numpy as np

def lz78(s):
    if not s: return 0
    chunks = set()
    i = 0
    count = 0
    while i < len(s):
        j = 1
        while i + j <= len(s) and s[i:i+j] in chunks:
            j += 1
        chunks.add(s[i:i+j])
        i += j
        count += 1
    return count

