import pandas as pd
import numpy as np

def get_max_alts(n, h):
    min_count = min(h, n - h)
    if min_count * 2 == n:
        return n - 1
    else:
        return 2 * min_count

df = pd.read_csv("/scratch/users/benpry/auto-psych/outer_loop_live/run2/data/subjective_randomness/experiment2/model_loop/responses.csv")

