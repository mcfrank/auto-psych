rel_alts_a = df['alts_a'] / np.maximum(max_alts_a, 1)

print("Corr rel_alts and periodicity:", rel_alts_a.corr(df['periodicity_a']))
print("Corr rel_alts and chose_left (A-B):")
max_alts_b = df.apply(lambda row: get_max_alts(row['n_b'], row['h_b']), axis=1)
rel_alts_b = df['alts_b'] / np.maximum(max_alts_b, 1)

diff = rel_alts_a - rel_alts_b
slope = np.polyfit(diff, df['chose_left'], 1)[0]
print("Slope rel_alts:", slope)
