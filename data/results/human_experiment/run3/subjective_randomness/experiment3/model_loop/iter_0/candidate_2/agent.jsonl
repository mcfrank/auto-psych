"""
People judge the randomness of a sequence by its distance from a subjective prototype (an ideal proportion of heads and an ideal alternation rate). However, they exhibit 'coincidence avoidance': they apply a discrete penalty to sequences that are exactly balanced (an exactly equal number of heads and tails), perceiving such perfect mathematical symmetry as a suspicious hallmark of human artificiality rather than natural chance.
"""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    # Stimulus inputs
    n_a = pm.Data("n_a", np.zeros(1, dtype="int64"))
    h_a = pm.Data("h_a", np.zeros(1, dtype="int64"))
    alts_a = pm.Data("alts_a", np.zeros(1, dtype="int64"))

    n_b = pm.Data("n_b", np.zeros(1, dtype="int64"))
    h_b = pm.Data("h_b", np.zeros(1, dtype="int64"))
    alts_b = pm.Data("alts_b", np.zeros(1, dtype="int64"))

    # Free cognitive parameters
    ideal_alts = pm.Beta("ideal_alts", alpha=5.0, beta=5.0)
    weight_alts = pm.HalfNormal("weight_alts", sigma=5.0)
    coincidence_penalty = pm.HalfNormal("coincidence_penalty", sigma=5.0)
    tau = pm.HalfNormal("tau", sigma=5.0)

    # Compute distances from prototype for sequence A
    p_h_a = pt.cast(h_a, "float64") / pt.cast(n_a, "float64")
    p_alts_a = pt.cast(alts_a, "float64") / pt.maximum(pt.cast(n_a - 1, "float64"), 1.0)

    dist_h_a = pt.abs(p_h_a - 0.5)
    dist_alts_a = pt.abs(p_alts_a - ideal_alts)

    # Exact balance indicator (1 if exactly equal heads and tails, 0 otherwise)
    is_balanced_a = pt.eq(h_a * 2, n_a)

    # Randomness score A (higher is more random)
    score_a = -(
        dist_h_a
        + weight_alts * dist_alts_a
        + pt.cast(is_balanced_a, "float64") * coincidence_penalty
    )

    # Compute distances from prototype for sequence B
    p_h_b = pt.cast(h_b, "float64") / pt.cast(n_b, "float64")
    p_alts_b = pt.cast(alts_b, "float64") / pt.maximum(pt.cast(n_b - 1, "float64"), 1.0)

    dist_h_b = pt.abs(p_h_b - 0.5)
    dist_alts_b = pt.abs(p_alts_b - ideal_alts)

    is_balanced_b = pt.eq(h_b * 2, n_b)

    # Randomness score B (higher is more random)
    score_b = -(
        dist_h_b
        + weight_alts * dist_alts_b
        + pt.cast(is_balanced_b, "float64") * coincidence_penalty
    )

    # Choice probability: clamp for numerical safety
    p_left_raw = pm.math.sigmoid(tau * (score_a - score_b))
    p_left = pm.Deterministic("p_left", pt.clip(p_left_raw, 1e-6, 1.0 - 1e-6))

    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
