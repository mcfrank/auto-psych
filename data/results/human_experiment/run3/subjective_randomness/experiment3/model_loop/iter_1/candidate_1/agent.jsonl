import pandas as pd
import numpy as np

def score(n, h, rep, alt):
    delta = 0.5
    alpha = 0.5
    bias_share = 0.5
    log_delta = np.log(delta)
    log_alpha = np.log(alpha)
    log_c = np.log(1.0 - delta) - np.log(2.0 * alpha + 2.0 * alpha**2)
    
    # motif
    stays = n - rep - alt
    log_motif = stays * log_delta + (rep + alt) * log_c + (rep + 2 * alt) * log_alpha
    
    # biased
    p = 0.85
    hh = h * np.log(p) + (n-h) * np.log(1-p)
    th = h * np.log(1-p) + (n-h) * np.log(p)
    m = max(hh, th)
    log_biased = np.log(0.5) + m + np.log(np.exp(hh-m) + np.exp(th-m))
    
    # regular
    log_reg_m = log_motif + np.log(1 - bias_share)
    log_reg_b = log_biased + np.log(bias_share)
    m2 = max(log_reg_m, log_reg_b)
    log_regular = m2 + np.log(np.exp(log_reg_m - m2) + np.exp(log_reg_b - m2))
    
    log_fair = n * np.log(0.5)
    return log_fair - log_regular

