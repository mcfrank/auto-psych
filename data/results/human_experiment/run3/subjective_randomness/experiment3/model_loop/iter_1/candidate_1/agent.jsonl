import numpy as np

def run_length_entropy(seq):
    if not seq: return 0.0
    runs = []
    current_run = 1
    for i in range(1, len(seq)):
        if seq[i] == seq[i-1]:
            current_run += 1
        else:
            runs.append(current_run)
            current_run = 1
    runs.append(current_run)
    
    # Calculate empirical probabilities
    counts = {}
    for r in runs:
        counts[r] = counts.get(r, 0) + 1
    
    entropy = 0.0
    total = len(runs)
    for r, count in counts.items():
        p = count / total
        entropy -= p * np.log(p)
        
    return entropy

print(run_length_entropy("HTHTHTHT"))
print(run_length_entropy("HHHHHHHH"))
print(run_length_entropy("HHTHTTHT"))
print(run_length_entropy("HHHTHTTT"))
