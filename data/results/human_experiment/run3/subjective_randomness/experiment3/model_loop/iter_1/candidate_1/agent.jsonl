import pandas as pd
import numpy as np
from scipy.optimize import minimize

def lz76(s):
    i = 0; c = 1; k = 1; n = len(s)
    if n == 0: return 0
    while i + k <= n:
        sub = s[i:i+k]
        found = False
        for j in range(0, i):
            if s[j:j+k] == sub: found = True; break
        if found: k += 1
        else: c += 1; i += k; k = 1
    return c

df = pd.read_csv('/scratch/users/benpry/auto-psych/outer_loop_live/run3/data/subjective_randomness/experiment3/model_loop/responses.csv')
lz_diff = df['sequence_a'].apply(lz76) - df['sequence_b'].apply(lz76)
y = df['chose_left'].values

def loss(params, X):
    beta, alpha = params
    p = 1 / (1 + np.exp(-(beta * X + alpha)))
    p = np.clip(p, 1e-6, 1 - 1e-6)
    return -np.sum(y * np.log(p) + (1 - y) * np.log(1 - p))

res_lz = minimize(loss, [1.0, 0.0], args=(lz_diff.values,))
print("LZ Log Loss:", res_lz.fun)

# Compare with max_run
run_diff = df['max_run_a'] - df['max_run_b']
res_run = minimize(loss, [-1.0, 0.0], args=(run_diff.values,))
print("Max Run Log Loss:", res_run.fun)
