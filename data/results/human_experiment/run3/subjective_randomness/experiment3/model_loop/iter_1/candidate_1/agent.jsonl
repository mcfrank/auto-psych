import pandas as pd
import itertools

def max_run(s):
    return max([len(list(g)) for k, g in itertools.groupby(s)])

cache = {}
def exact_max_run_prob(s):
    N = len(s)
    M = max_run(s)
    if (N, M) in cache: return cache[(N, M)]
    valid = 0
    total = 2**N
    for x in itertools.product("HT", repeat=N):
        m = max([len(list(g)) for k, g in itertools.groupby(x)])
        if m >= M:
            valid += 1
    p = valid / total
    cache[(N, M)] = p
    return p

