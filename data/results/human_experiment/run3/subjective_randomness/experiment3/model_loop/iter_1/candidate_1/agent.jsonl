import numpy as np
from collections import Counter

def block_entropy(seq, k=2):
    if len(seq) < k: return 0.0
    blocks = [seq[i:i+k] for i in range(len(seq)-k+1)]
    counts = Counter(blocks)
    total = len(blocks)
    entropy = 0.0
    for count in counts.values():
        p = count / total
        entropy -= p * np.log2(p)
    return entropy

