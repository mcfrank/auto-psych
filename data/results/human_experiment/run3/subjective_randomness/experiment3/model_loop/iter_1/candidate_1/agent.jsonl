"""We refine the Bayesian diagnosticity model to address its under-penalization of large maximum runs. We modify the functional form of the 'regular' alternative hypothesis so that its log-likelihood includes a term that grows exponentially with the sequence's maximum run length (rather than only linearly with total continuations). This reflects a cognitive expectation that non-random generators deliberately produce localized, extremely long anomalous streaks, causing people to severely penalize sequences containing them."""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

BIAS_HEAD_PROB = 0.85

def _logsumexp2(a, b):
    m = pt.maximum(a, b)
    return m + pt.log(pt.exp(a - m) + pt.exp(b - m))

def _log_motif(n, rep_motifs, alt_motifs, max_run, log_delta, log_c, log_alpha, streak_weight):
    n_f = pt.cast(n, "float64")
    n1 = pt.cast(rep_motifs, "float64")
    n2 = pt.cast(alt_motifs, "float64")
    max_run_f = pt.cast(max_run, "float64")
    stays = n_f - n1 - n2  # within-motif continuations; >= 0 by construction
    
    # We add streak_weight * max_run_f to the regular motif likelihood.
    # This exponentially boosts the probability of sequences with large max runs under the regular hypothesis,
    # causing them to be heavily penalized in the randomness score.
    return stays * log_delta + (n1 + n2) * log_c + (n1 + 2.0 * n2) * log_alpha + streak_weight * max_run_f

def _log_biased(n, h):
    n_f = pt.cast(n, "float64")
    h_f = pt.cast(h, "float64")
    tails_f = n_f - h_f
    head_heavy = h_f * np.log(BIAS_HEAD_PROB) + tails_f * np.log(1.0 - BIAS_HEAD_PROB)
    tail_heavy = h_f * np.log(1.0 - BIAS_HEAD_PROB) + tails_f * np.log(BIAS_HEAD_PROB)
    return _logsumexp2(np.log(0.5) + head_heavy, np.log(0.5) + tail_heavy)

def _randomness(n, h, rep_motifs, alt_motifs, max_run, log_delta, log_c, log_alpha, streak_weight, bias_share):
    log_fair = pt.cast(n, "float64") * np.log(0.5)
    log_motif = _log_motif(n, rep_motifs, alt_motifs, max_run, log_delta, log_c, log_alpha, streak_weight)
    log_biased = _log_biased(n, h)
    log_regular = _logsumexp2(
        pt.log(1.0 - bias_share) + log_motif,
        pt.log(bias_share) + log_biased,
    )
    return log_fair - log_regular

with pm.Model() as model:
    n_a = pm.Data("n_a", np.zeros(1, dtype="int64"))
    h_a = pm.Data("h_a", np.zeros(1, dtype="int64"))
    rep_motifs_a = pm.Data("rep_motifs_a", np.zeros(1, dtype="int64"))
    alt_motifs_a = pm.Data("alt_motifs_a", np.zeros(1, dtype="int64"))
    max_run_a = pm.Data("max_run_a", np.zeros(1, dtype="int64"))
    
    n_b = pm.Data("n_b", np.zeros(1, dtype="int64"))
    h_b = pm.Data("h_b", np.zeros(1, dtype="int64"))
    rep_motifs_b = pm.Data("rep_motifs_b", np.zeros(1, dtype="int64"))
    alt_motifs_b = pm.Data("alt_motifs_b", np.zeros(1, dtype="int64"))
    max_run_b = pm.Data("max_run_b", np.zeros(1, dtype="int64"))
    
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))

    delta = pm.Uniform("delta", lower=0.01, upper=0.99)
    alpha = pm.Uniform("alpha", lower=0.01, upper=0.99)
    bias_share = pm.Uniform("bias_share", lower=0.01, upper=0.99)
    beta = pm.Uniform("beta", lower=0.2, upper=12.0)
    side_bias = pm.Uniform("side_bias", lower=-2.0, upper=2.0)
    
    # New parameter for the accelerating streak penalty
    streak_weight = pm.HalfNormal("streak_weight", sigma=2.0)

    log_delta = pt.log(delta)
    log_alpha = pt.log(alpha)
    log_c = pt.log(1.0 - delta) - pt.log(2.0 * alpha + 2.0 * alpha**2)

    score_a = _randomness(
        n_a, h_a, rep_motifs_a, alt_motifs_a, max_run_a, log_delta, log_c, log_alpha, streak_weight, bias_share
    )
    score_b = _randomness(
        n_b, h_b, rep_motifs_b, alt_motifs_b, max_run_b, log_delta, log_c, log_alpha, streak_weight, bias_share
    )

    p_left_raw = pm.math.sigmoid(beta * (score_a - score_b) + side_bias)
    p_left = pm.Deterministic("p_left", pt.clip(p_left_raw, 1e-6, 1.0 - 1e-6))
    
    pm.Bernoulli("response", p=p_left, observed=chose_left)
