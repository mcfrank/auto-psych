    for i in range(len(seq)-1): counts[seq[i:i+2]] += 1
    
    n_HH = counts['HH']
    n_HT = counts['HT']
    n_TH = counts['TH']
    n_TT = counts['TT']
    
    N = len(seq)
    
    # log P(D | Random)
    log_p_rand = (N-1) * np.log(0.5)
    
    # log P(D | Markov) with Beta(1,1) priors
    log_p_markov = betaln(n_HH + 1, n_HT + 1) + betaln(n_TT + 1, n_TH + 1)
    
    return log_p_rand - log_p_markov

