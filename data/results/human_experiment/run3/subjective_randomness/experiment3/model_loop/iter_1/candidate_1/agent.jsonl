    i = 0; c = 1; k = 1; n = len(s)
    if n == 0: return 0
    while i + k <= n:
        sub = s[i:i+k]
        found = False
        for j in range(0, i):
            if s[j:j+k] == sub:
                found = True
                break
        if found: k += 1
        else: c += 1; i += k; k = 1
    return c

