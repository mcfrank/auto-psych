def markov_entropy(seq):
    if len(seq) < 2: return 0.0
    counts = {'HH':0, 'HT':0, 'TH':0, 'TT':0}
    for i in range(len(seq)-1): counts[seq[i:i+2]] += 1
    n_H = counts['HH'] + counts['HT']
    n_T = counts['TH'] + counts['TT']
    entropy = 0.0
    if n_H > 0:
        p_HH = counts['HH'] / n_H; p_HT = counts['HT'] / n_H
        if p_HH > 0: entropy -= (n_H / (len(seq)-1)) * p_HH * np.log2(p_HH)
        if p_HT > 0: entropy -= (n_H / (len(seq)-1)) * p_HT * np.log2(p_HT)
    if n_T > 0:
        p_TH = counts['TH'] / n_T; p_TT = counts['TT'] / n_T
        if p_TH > 0: entropy -= (n_T / (len(seq)-1)) * p_TH * np.log2(p_TH)
        if p_TT > 0: entropy -= (n_T / (len(seq)-1)) * p_TT * np.log2(p_TT)
    return entropy

markov_diff = df['sequence_a'].apply(markov_entropy) - df['sequence_b'].apply(markov_entropy)
res_markov = minimize(loss, [1.0, 0.0], args=(markov_diff.values,))
print("Markov Entropy Log Loss:", res_markov.fun)
