"""
People judge the randomness of a sequence by translating it into a sequence of local transitions (switches and stays) and evaluating its log-likelihood under a subjective first-order Markov model of these transitions. They score sequences based on how well the transition-to-transition changes align with two distinct subjective expectations: a belief that runs of identical outcomes should end (gambler's fallacy) and a belief that alternating patterns should continue (generating alternating motifs).
"""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

def compute_features(sequence_a: str, sequence_b: str) -> dict:
    """Return counts of transition types for the subjective Markov model."""
    def get_counts(seq):
        seq = seq.strip().upper()
        counts = {
            "start_alt": 0.0,
            "start_run": 0.0,
            "run_cont": 0.0,
            "run_end": 0.0,
            "alt_cont": 0.0,
            "alt_end": 0.0
        }
        if len(seq) >= 2:
            first_bi = seq[0:2]
            if first_bi in ("HT", "TH"):
                counts["start_alt"] = 1.0
            else:
                counts["start_run"] = 1.0
        
        for i in range(len(seq) - 2):
            tri = seq[i:i+3]
            if tri in ("HHH", "TTT"):
                counts["run_cont"] += 1.0
            elif tri in ("HHT", "TTH"):
                counts["run_end"] += 1.0
            elif tri in ("HTH", "THT"):
                counts["alt_cont"] += 1.0
            elif tri in ("HTT", "THH"):
                counts["alt_end"] += 1.0
                
        return counts

    ca = get_counts(sequence_a)
    cb = get_counts(sequence_b)
    
    return {
        "start_alt_a": ca["start_alt"],
        "start_run_a": ca["start_run"],
        "run_cont_a": ca["run_cont"],
        "run_end_a": ca["run_end"],
        "alt_cont_a": ca["alt_cont"],
        "alt_end_a": ca["alt_end"],
        "start_alt_b": cb["start_alt"],
        "start_run_b": cb["start_run"],
        "run_cont_b": cb["run_cont"],
        "run_end_b": cb["run_end"],
        "alt_cont_b": cb["alt_cont"],
        "alt_end_b": cb["alt_end"],
    }

with pm.Model() as model:
    # Read the custom features
    start_alt_a = pm.Data("start_alt_a", np.zeros(1, dtype="float64"))
    start_run_a = pm.Data("start_run_a", np.zeros(1, dtype="float64"))
    run_cont_a = pm.Data("run_cont_a", np.zeros(1, dtype="float64"))
    run_end_a = pm.Data("run_end_a", np.zeros(1, dtype="float64"))
    alt_cont_a = pm.Data("alt_cont_a", np.zeros(1, dtype="float64"))
    alt_end_a = pm.Data("alt_end_a", np.zeros(1, dtype="float64"))
    
    start_alt_b = pm.Data("start_alt_b", np.zeros(1, dtype="float64"))
    start_run_b = pm.Data("start_run_b", np.zeros(1, dtype="float64"))
    run_cont_b = pm.Data("run_cont_b", np.zeros(1, dtype="float64"))
    run_end_b = pm.Data("run_end_b", np.zeros(1, dtype="float64"))
    alt_cont_b = pm.Data("alt_cont_b", np.zeros(1, dtype="float64"))
    alt_end_b = pm.Data("alt_end_b", np.zeros(1, dtype="float64"))

    # Free cognitive parameters
    # Probability of a switch on the first transition
    theta_switch_raw = pm.Beta("theta_switch", alpha=2.0, beta=2.0)
    theta_switch = pt.clip(theta_switch_raw, 1e-5, 1.0 - 1e-5)
    
    # Probability of a switch given the previous transition was a stay (run ends)
    theta_run_end_raw = pm.Beta("theta_run_end", alpha=2.0, beta=2.0)
    theta_run_end = pt.clip(theta_run_end_raw, 1e-5, 1.0 - 1e-5)
    
    # Probability of a switch given the previous transition was a switch (alternation continues)
    theta_alt_cont_raw = pm.Beta("theta_alt_cont", alpha=2.0, beta=2.0)
    theta_alt_cont = pt.clip(theta_alt_cont_raw, 1e-5, 1.0 - 1e-5)

    # Choice noise
    tau = pm.HalfNormal("tau", sigma=1.0)

    # Log-likelihood of sequence A under the subjective Markov model
    log_L_a = (
        start_alt_a * pt.log(theta_switch) +
        start_run_a * pt.log(1.0 - theta_switch) +
        run_end_a * pt.log(theta_run_end) +
        run_cont_a * pt.log(1.0 - theta_run_end) +
        alt_cont_a * pt.log(theta_alt_cont) +
        alt_end_a * pt.log(1.0 - theta_alt_cont)
    )
    
    # Log-likelihood of sequence B
    log_L_b = (
        start_alt_b * pt.log(theta_switch) +
        start_run_b * pt.log(1.0 - theta_switch) +
        run_end_b * pt.log(theta_run_end) +
        run_cont_b * pt.log(1.0 - theta_run_end) +
        alt_cont_b * pt.log(theta_alt_cont) +
        alt_end_b * pt.log(1.0 - theta_alt_cont)
    )

    # Choice probability
    p_left_raw = pm.math.sigmoid(tau * (log_L_a - log_L_b))
    p_left = pm.Deterministic("p_left", pt.clip(p_left_raw, 1e-6, 1.0 - 1e-6))

    # Observed response
    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))
    pm.Bernoulli("response", p=p_left, observed=chose_left)
