"""People judge the randomness of a sequence by comparing its features to a subjective ideal using Bayesian smoothing, but they intuitively understand that imbalanced sequences must have fewer alternations. Therefore, rather than using a fixed ideal alternation rate, they dynamically adjust their expected alternation rate downwards for sequences with a skewed heads/tails balance."""

import numpy as np
import pymc as pm
import pytensor.tensor as pt

with pm.Model() as model:
    # Feature inputs
    n_a = pm.Data("n_a", np.zeros(1, dtype="int64"))
    n_b = pm.Data("n_b", np.zeros(1, dtype="int64"))

    imbalance_a = pm.Data("imbalance_a", np.zeros(1, dtype="float64"))
    imbalance_b = pm.Data("imbalance_b", np.zeros(1, dtype="float64"))

    p_a = pm.Data("p_a", np.zeros(1, dtype="float64"))
    p_b = pm.Data("p_b", np.zeros(1, dtype="float64"))

    p_alts_a = pm.Data("p_alts_a", np.zeros(1, dtype="float64"))
    p_alts_b = pm.Data("p_alts_b", np.zeros(1, dtype="float64"))

    chose_left = pm.Data("chose_left", np.zeros(1, dtype="int64"))

    # Cognitive parameters
    # The baseline ideal alternation rate people expect for a balanced sequence
    theta_alt = pm.Uniform("theta_alt", lower=0.35, upper=0.95)
    # The relative weight of alternations vs. heads balance
    alt_weight = pm.Uniform("alt_weight", lower=0.01, upper=0.99)
    balance_weight = 1.0 - alt_weight

    # Pseudo-counts for Bayesian smoothing of the proportions
    K_bal = pm.Uniform("K_bal", lower=0.0, upper=20.0)
    K_alt = pm.Uniform("K_alt", lower=0.0, upper=20.0)

    # Scaling parameter and side bias for the decision rule
    beta = pm.Uniform("beta", lower=0.1, upper=20.0)
    side_bias = pm.Uniform("side_bias", lower=-2.0, upper=2.0)

    # Calculate denominators
    n_a_f = pt.cast(n_a, "float64")
    n_b_f = pt.cast(n_b, "float64")

    n_alts_a_f = pt.cast(pt.maximum(n_a - 1, 1), "float64")
    n_alts_b_f = pt.cast(pt.maximum(n_b - 1, 1), "float64")

    # Dynamic alternation ideals
    # For a completely random sequence with heads proportion p, the expected
    # alternation rate is proportional to 2 * p * (1 - p).
    # We normalize this factor so it equals 1 when p = 0.5.
    # Therefore, dynamic_ideal = theta_alt * (4 * p * (1 - p))
    dynamic_theta_alt_a = theta_alt * (4.0 * p_a * (1.0 - p_a))
    dynamic_theta_alt_b = theta_alt * (4.0 * p_b * (1.0 - p_b))

    # Smoothed deviations: (n / (n + K)) * raw_deviation
    # For heads/tails balance, raw deviation is imbalance = |p - 0.5|
    smooth_imb_a = (n_a_f / (n_a_f + K_bal)) * imbalance_a
    smooth_imb_b = (n_b_f / (n_b_f + K_bal)) * imbalance_b

    # For alternations, raw deviation is the distance from the dynamic ideal
    raw_alt_dev_a = pt.abs(p_alts_a - dynamic_theta_alt_a)
    raw_alt_dev_b = pt.abs(p_alts_b - dynamic_theta_alt_b)

    smooth_alt_dev_a = (n_alts_a_f / (n_alts_a_f + K_alt)) * raw_alt_dev_a
    smooth_alt_dev_b = (n_alts_b_f / (n_alts_b_f + K_alt)) * raw_alt_dev_b

    # Score sequences based on their smoothed distance from the ideal
    score_a = -(balance_weight * smooth_imb_a + alt_weight * smooth_alt_dev_a)
    score_b = -(balance_weight * smooth_imb_b + alt_weight * smooth_alt_dev_b)

    # Softmax decision rule
    p_left_raw = pm.math.sigmoid(beta * (score_a - score_b) + side_bias)
    p_left = pm.Deterministic("p_left", pt.clip(p_left_raw, 1e-6, 1.0 - 1e-6))

    pm.Bernoulli("response", p=p_left, observed=chose_left)
