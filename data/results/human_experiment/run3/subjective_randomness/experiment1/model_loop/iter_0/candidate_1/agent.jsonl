import numpy as np
from scipy.special import gammaln

def log_binom(k, n, p):
    # k and n can be arrays
    comb = gammaln(n + 1) - gammaln(k + 1) - gammaln(n - k + 1)
    return comb + k * np.log(p) + (n - k) * np.log(1 - p)

