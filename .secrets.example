# Copy to .secrets (gitignored) or export these locally. Never commit real values.
# The Slurm harness (scripts/outer_loop_live/_env.sh) sources this file.

# Prolific REST API token — create/publish studies and poll submissions.
# Account settings -> API tokens. Needed for --prolific-mode test/live.
PROLIFIC_API_TOKEN=replace-me

# Google Gemini API key. Only the simulated paths use it (LLM browser steering
# and the closed/Gemini participant backend); a pure live HUMAN run does not.
GOOGLE_API_KEY=replace-me

# Firebase CI token for non-interactive `firebase deploy` from compute nodes.
# Generate once on a machine with a browser:  firebase login:ci
# (or: npx -y firebase-tools login:ci) and paste the token here.
# Needed for --deploy-target firebase.
FIREBASE_TOKEN=replace-me
