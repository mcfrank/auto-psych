#!/usr/bin/env bash
# prove_it: full test suite—runs before every git commit
set -e
trap 'rc=$?; command -v prove_it >/dev/null 2>&1 && prove_it record --name full-tests --result $rc' EXIT
# PYTENSOR_FLAGS="cxx=" disables the C linker; macOS sandboxing otherwise
# breaks PyTensor compilation (the ArviZ/PyTensor cache-dir issue).
exec env PYTENSOR_FLAGS="cxx=" .venv/bin/python -m pytest -q
