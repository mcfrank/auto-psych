# Template for cluster-side environment. Copy to remote_jobs/.env.local (gitignored) and edit.
#
#   cp remote_jobs/.env.example remote_jobs/.env.local
#   # then edit values below
#
# remote_jobs/submit.py and remote_jobs/sync_from_remote.sh source .env.local automatically.

# SSH alias for the cluster login node. Define this in ~/.ssh/config so the alias resolves
# (recommended; lets you keep ProxyJump, IdentityFile, controlmaster, etc. local).
REMOTE_HOST=sherlock

# Where the auto-psych repo lives on the cluster. Use literal '$HOME' so it expands
# remote-side. submit.py runs `cd "$REMOTE_PROJECT_DIR" && git pull` before each sbatch.
REMOTE_PROJECT_DIR='$HOME/auto-psych'

# Where SLURM jobs write their outputs and logs. Sherlock exposes $SCRATCH; if your
# cluster uses a different env var (e.g. $WORK on TACC, $GROUP_HOME, etc.) set it
# explicitly here -- pipeline.slurm and sync_from_remote.sh both read this value.
REMOTE_SCRATCH_DIR='$SCRATCH/auto-psych'
