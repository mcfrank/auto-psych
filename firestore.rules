rules_version = '2';

// All participant data is written and read exclusively by the auto-psych Cloud
// Functions (`/submit`, `/results`) using the Firebase Admin SDK, which bypasses
// these security rules. Browser clients never touch Firestore directly, so we
// deny ALL direct client access — the database must never be publicly readable
// or writable.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
