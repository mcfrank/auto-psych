# Prolific settings for test_prolific and (future) live mode.
# Copy to prolific_config.yaml and set test_participant_email.
# The test participant email must NOT already be registered on Prolific.

estimated_completion_time: 5   # minutes
completion_code: AUTO_PSYCH_COMPLETE
# What Prolific does when a worker submits the completion code:
#   AUTOMATICALLY_APPROVE (default) — pay everyone who finishes; exclude bad data
#                                     analytically (the monitor flags degenerate runs).
#   MANUALLY_REVIEW — hold submissions for you to approve/reject.
completion_code_action: AUTOMATICALLY_APPROVE
test_participant_email: "your-test@example.com"   # required for --mode test_prolific
total_available_places: 1
reward: 50   # cents
name: "Auto-psych test"
description: "Test run (test participant)."

# Data-quality eligibility (live studies only): participants are restricted to
# US residents fluent in English with an approval rate >= min_approval_rate.
# Residence and language defaults are fixed in code; only the approval floor is
# configurable here.
min_approval_rate: 98   # percent (0-100)
